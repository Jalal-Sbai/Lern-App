<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="de.lernapp.lern_app.controllers.QuizController" 
      spacing="20" prefWidth="800" prefHeight="500">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Quiz Bereich (Links) -->
    <VBox spacing="15" alignment="TOP_CENTER" HBox.hgrow="ALWAYS" prefWidth="400">
        <Label text="Quiz" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        
        <Label fx:id="questionLabel" text="Frage lädt..." wrapText="true" 
               style="-fx-font-size: 16px; -fx-padding: 10;" minHeight="80"/>
        
        <Button fx:id="btnOptionA" text="A" prefWidth="300" onAction="#handleAnswerA"/>
        <Button fx:id="btnOptionB" text="B" prefWidth="300" onAction="#handleAnswerB"/>
        <Button fx:id="btnOptionC" text="C" prefWidth="300" onAction="#handleAnswerC"/>
        <Button fx:id="btnOptionD" text="D" prefWidth="300" onAction="#handleAnswerD"/>
        
        <Label fx:id="feedbackLabel" text="" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        
        <Button fx:id="btnNext" text="Nächste Frage" prefWidth="200" onAction="#handleNext" disable="true" visible="false"/>
    </VBox>

    <!-- Leaderboard Bereich (Rechts) -->
    <VBox spacing="10" alignment="TOP_CENTER" prefWidth="300">
        <Label text="Bestenliste" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <ListView fx:id="leaderboardListView" VBox.vgrow="ALWAYS"/>
    </VBox>
    
</HBox>
